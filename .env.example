# Copy to .env and fill in your values. .env is git-ignored.

# API key — accepts HF_TOKEN, API_KEY, or GROQ_API_KEY (checked in that order)
HF_TOKEN=hf_...

# LLM endpoint and model (defaults shown)
# API_BASE_URL=https://api.groq.com/openai/v1
# MODEL_NAME=llama-3.3-70b-versatile

# Environment connection — choose ONE:
#
# Option A: Docker image name (hackathon eval mode — spins up container locally)
# IMAGE_NAME=intercompany-dispute-env:latest
#
# Option B: Connect to running server (local or HF Space)
# ENV_URL=ws://localhost:8000
# ENV_URL=wss://your-username-intercompany-dispute-env.hf.space
#
# Option C: In-process (local dev, no Docker needed — default if neither above is set)
# USE_INPROCESS=true
